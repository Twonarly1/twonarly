{
  "name": "twonarly1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_ENV=development bun --bun vite dev --port 3000 & NODE_ENV=development bun --bun run src/lib/db/server.ts",
    "build": "NODE_ENV=production bun --bun vite build",
    "lint": "biome lint",
    "format": "biome format --write",
    "check": "biome check",
    "db:generate": "bun --env-file .env.local drizzle-kit generate --config src/lib/config/drizzle.config.ts",
    "db:migrate": "bun --env-file .env.local drizzle-kit migrate --config src/lib/config/drizzle.config.ts && GRAPHILE_ENV=development bun graphile:generate",
    "db:studio": "bun --env-file .env.local drizzle-kit studio --config src/lib/config/drizzle.config.ts",
    "db:seed-tasks": "bun --env-file .env.local tsx src/lib/db/scripts/generate-tasks.ts",
    "graphql:generate": " bun --bun graphql-codegen --config src/lib/config/codegen.config.ts",
    "graphql:generate:watch": "bun graphql:generate -w",
    "graphile:generate": "NODE_ENV=development GRAPHILE_ENV=development bun run --env-file .env.local src/lib/db/scripts/generate-schema.ts",
    "knip": "knip-bun --config src/lib/config/knip.config.ts",
    "tangrams:generate": "bunx tangrams generate --config src/lib/config/tangrams.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.992.0",
    "@elysiajs/cors": "^1.4.1",
    "@elysiajs/graphql-yoga": "^1.4.0",
    "@envelop/parser-cache": "^10.0.0",
    "@graphile/simplify-inflection": "^8.0.0-rc.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@t3-oss/env-core": "^0.13.10",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-devtools": "^0.7.0",
    "@tanstack/react-form": "^1.27.7",
    "@tanstack/react-query": "^5.90.16",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@tanstack/react-router": "^1.159.5",
    "@tanstack/react-router-devtools": "^1.132.0",
    "@tanstack/react-router-ssr-query": "^1.131.7",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.18",
    "@uiw/color-convert": "^2.9.5",
    "better-auth": "^1.4.18",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-kit": "^0.31.8",
    "drizzle-orm": "^0.45.1",
    "elysia": "^1.4.19",
    "file-type": "^21.3.3",
    "grafast": "^1.0.0-rc.3",
    "graphile-export": "^1.0.0-rc.2",
    "graphql": "^16.12.0",
    "graphql-yoga": "^5.18.0",
    "knip": "^5.81.0",
    "lucide-react": "^0.562.0",
    "next-themes": "^0.4.6",
    "pg": "^8.16.3",
    "postgraphile": "^5.0.0-rc.3",
    "postgraphile-plugin-connection-filter": "^3.0.0-rc.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-colorful": "^5.6.1",
    "react-dom": "^19.2.0",
    "react-hotkeys-hook": "^5.2.3",
    "replace-in-file": "^8.4.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.0.2",
    "tailwindcss": "^4.0.6",
    "ts-pattern": "^5.9.0",
    "tw-animate-css": "^1.3.6",
    "ua-parser-js": "^2.0.9",
    "usehooks-ts": "^3.1.1",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.5",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.11",
    "@graphql-codegen/cli": "^6.1.1",
    "@graphql-codegen/import-types-preset": "^3.0.1",
    "@graphql-codegen/plugin-helpers": "^6.1.0",
    "@graphql-codegen/typescript": "^5.0.7",
    "@graphql-codegen/typescript-graphql-request": "^6.4.0",
    "@graphql-codegen/typescript-msw": "^3.0.1",
    "@graphql-codegen/typescript-react-query": "^6.1.1",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@types/node": "^22.10.2",
    "@types/pg": "^8.10.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "tsx": "^4.0.0",
    "typescript": "^5.7.2",
    "vite": "^7.1.7"
  }
